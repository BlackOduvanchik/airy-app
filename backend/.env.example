# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/airy?schema=public"

# Redis (BullMQ + cache)
REDIS_URL="redis://localhost:6379"

# Auth (JWT)
JWT_SECRET=your-jwt-secret-min-32-chars

# Anthropic (AI)
ANTHROPIC_API_KEY=sk-ant-...

# Exchange rates (e.g. exchangerate.host or frankfurter.app)
EXCHANGE_RATE_API_URL=https://api.frankfurter.app
EXCHANGE_RATE_CACHE_TTL_SECONDS=3600

# Feature limits (free tier)
FREE_MONTHLY_AI_ANALYSES=10

# Optional: object storage for fallback image upload
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
